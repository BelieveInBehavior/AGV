# ── AI：OpenAI 兼容协议（故事分析、分镜；亦可前端「AI 设置」按用户覆盖）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# FAL 图像生成（可选；亦可设置页配置）
FAL_API_KEY=your-fal-api-key
FAL_IMAGE_MODEL=fal-ai/flux/schnell

# 生视频（预留）
VIDEO_API_BASE_URL=
VIDEO_MODEL=

# ── Celery Worker 配置 ─────────────────────────────────
