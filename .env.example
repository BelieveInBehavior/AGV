MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=agv
# Docker 的 api/worker 会再加载 server/.env（若存在），其中 MONGODB_* 会覆盖本文件。远程业务库（如 beeseen）请写在 server/.env，勿把带密码的连接串提交到 Git。
#
# 前端（Vite）可选：`client/.env.development` 中的 `VITE_API_ORIGIN`（如 http://localhost:3011）用于开发时直连 API，见 README「启动前端」。
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRES_IN=604800
ALIYUN_SMS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sign_name
ALIYUN_SMS_TEMPLATE_CODE=your_template_code
SMS_CODE_EXPIRE_SECONDS=300
SEND_CODE_COOLDOWN_SECONDS=60
TEST_PHONE_NUMBER=15000361623
TEST_PHONE_CODE=123456
CWEI_PORT=3001

# ── AI：OpenAI 兼容协议（故事分析、分镜；亦可前端「AI 设置」按用户覆盖）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# FAL 图像生成（可选；亦可设置页配置）
FAL_API_KEY=your-fal-api-key
FAL_IMAGE_MODEL=fal-ai/flux/schnell
# 有参考图时 Worker 首尾帧/分镜生图优先使用的图生图模型（失败则回退为 FAL_IMAGE_MODEL 文生图）
FAL_IMAGE_I2I_MODEL=fal-ai/flux/dev/image-to-image

# 生视频（OpenAI 兼容式 POST：/VIDEO_API_PATH，Bearer Key；可与设置页覆盖）
VIDEO_API_BASE_URL=
VIDEO_API_KEY=
VIDEO_API_PATH=v1/videos
VIDEO_MODEL=

# Ark 内容生视频（独立接口 /api/generate/videos/ark/tasks）
ARK_VIDEO_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_VIDEO_API_KEY=
ARK_VIDEO_MODEL=doubao-seedance-2-0-260128

# ── Celery Worker 配置 ─────────────────────────────────
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_SOFT_TIME_LIMIT=900
CELERY_TASK_TIME_LIMIT=1200

# ── OpenTelemetry（可选；API + Worker OTLP HTTP traces）────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=agv-local
